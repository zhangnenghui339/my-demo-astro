---
import Layout from "../../../layouts/Layout.astro";
import QuickAnswer from "../../../components/QuickAnswer.astro";
import AffiliateLink from "../../../components/AffiliateLink.astro";
import LeadMagnetGate from "../../../components/LeadMagnetGate.astro";
import pseoData from "../../../data/pseo-jobs.json";
import { resumeBuilders } from "../../../data/resume-builders";
import { atsJobs } from "../../../data/ats-jobs";
import { templates } from "../../../data/templates";
import { stackedSchema, breadcrumbSchema } from "../../../utils/seo";
import { withBase } from "../../../utils/site";

type PseoJob = (typeof pseoData.jobs)[number];

export function getStaticPaths() {
  return pseoData.jobs.map((job) => ({ params: { slug: job.slug }, props: { job } }));
}

interface Props {
  job: PseoJob;
}
const { job } = Astro.props;

const path = `/best/ai-resume-builder/${job.slug}/`;
const builderBySlug = new Map(resumeBuilders.map((b) => [b.slug, b]));
const picks = job.toolPicks
  .map((p) => ({ ...p, builder: builderBySlug.get(p.tool) }))
  .filter((p) => p.builder);

// 内链只指向真实存在的页面（红线7）
const roleSlug = job.jobTitle.toLowerCase().replace(/[^a-z0-9]+/g, "-");
const checkerJob = atsJobs.find((a) => a.slug === roleSlug) ?? null;
const template =
  templates.find((t) => t.role.toLowerCase() === job.jobTitle.toLowerCase()) ??
  templates.find((t) => t.slug === "ats-classic") ??
  null;

const seniorityLabel: Record<string, string> = {
  entry: "Entry-level",
  mid: "Mid-level",
  senior: "Senior",
  switcher: "Career changer",
};

const jsonLd = [
  stackedSchema({
    headline: job.title,
    description: job.description,
    path,
    dateModified: job.lastVerified ? `${job.lastVerified}-01` : undefined,
    items: picks.map((p) => ({
      name: p.builder!.name,
      url: `/best/ai-resume-builder/${job.slug}/#${p.tool}`,
    })),
    faqs: job.faq.map((f) => ({ question: f.q, answer: f.a })),
  }),
  breadcrumbSchema([
    { name: "Home", path: "/" },
    { name: "Reviews", path: "/best/ai-resume-builder/" },
    { name: job.title, path },
  ]),
];
---

<Layout title={`${job.title} - CareerRadar`} description={job.description} jsonLd={jsonLd}>
  <section class="cr-page">
    <div class="cr-wrap">
      <p class="cr-crumb">
        <a href={withBase("/best/ai-resume-builder/")}>Reviews</a> / {job.jobTitle} ·
        {seniorityLabel[job.seniority] ?? job.seniority}
      </p>
      <h1 class="cr-h1" style="font-size:clamp(1.9rem,4.2vw,3rem);margin-top:12px;max-width:24ch;">
        {job.title}
      </h1>
      <p class="cr-meta-row">
        {job.industry} · Typical range: {job.salaryRange} ·
        <a href={withBase("/how-we-test/")}>How we test →</a>
      </p>

      <QuickAnswer answer={job.quickAnswer} lastVerified={job.lastVerified} />

      <h2 style="margin-top:34px;">Why generic resume advice fails at this level</h2>
      <ul>
        {job.painPoints.map((p) => <li>{p}</li>)}
      </ul>

      <h2 style="margin-top:34px;">Our picks for {seniorityLabel[job.seniority]?.toLowerCase()} {job.jobTitle.toLowerCase()}s</h2>
      <div style="display:grid;gap:16px;margin-top:16px;">
        {picks.map((p, i) => (
          <article class="cr-card" id={p.tool}>
            <div class="cr-card__body">
              <p class="cr-card__tag">#{i + 1} · {p.builder!.verdict}</p>
              <h3 class="cr-card__title">{p.builder!.name}</h3>
              <p>{p.reason}</p>
              <p style="font-size:.88rem;opacity:.85;">
                Free tier: {p.builder!.freeTier} · From {p.builder!.price}
              </p>
              <div style="display:flex;gap:10px;flex-wrap:wrap;margin-top:10px;">
                <AffiliateLink tool={p.tool} pos="card">Try {p.builder!.name} →</AffiliateLink>
                <a
                  class="cr-btn cr-btn--sm"
                  style="background:transparent;color:#a9752a;border:1px solid var(--line);"
                  href={withBase("/best/ai-resume-builder/")}
                >
                  Full comparison →
                </a>
              </div>
            </div>
          </article>
        ))}
      </div>
      <p class="cr-disc" style="margin-top:12px;">
        Some links above are affiliate links — see our <a href={withBase("/disclosure/")}>disclosure</a>.
        Rankings come from our own tests, not commissions.
      </p>

      <h2 style="margin-top:34px;">Keywords recruiters search for this role</h2>
      <p>
        Mirror these exact phrases where they honestly apply — recruiters query their ATS with
        job-posting vocabulary, and exact strings win:
      </p>
      <ul>
        {job.keywords.map((k) => <li><code>{k}</code></li>)}
      </ul>

      <h2 style="margin-top:34px;">FAQ</h2>
      {job.faq.map((f) => (
        <details style="margin-top:10px;">
          <summary style="cursor:pointer;font-weight:600;">{f.q}</summary>
          <p style="margin-top:8px;">{f.a}</p>
        </details>
      ))}

      <div style="margin-top:36px;display:grid;gap:12px;">
        {checkerJob && (
          <a class="cr-btn" href={withBase(`/tools/ats-checker/${checkerJob.slug}/`)}>
            Free {job.jobTitle} ATS resume check →
          </a>
        )}
        {template && (
          <a
            class="cr-btn"
            style="background:transparent;color:#a9752a;border:1px solid var(--line);"
            href={withBase(`/templates/${template.slug}/`)}
          >
            {template.role === "Any role" ? "ATS-safe" : job.jobTitle} resume template (free) →
          </a>
        )}
      </div>

      <div style="margin-top:30px;">
        <LeadMagnetGate
          variant="comparison"
          sourceTag="tools-comparison"
          ctaText="Get the full 12-tool comparison PDF"
          helperText="Every tool, every price, ATS-format notes — one page."
          modalTitle="12 AI Resume Tools Compared (PDF)"
          modalCopy="The comparison table plus a decision guide by scenario, free."
          modalId={`pseo-${job.slug}`}
        />
      </div>
    </div>
  </section>
</Layout>
