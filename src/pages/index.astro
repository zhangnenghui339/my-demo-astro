---
import Layout from "../layouts/Layout.astro";
import { withBase } from "../utils/site";

const pillars = [
  {
    tag: "01",
    title: "Honest, ATS-tested reviews",
    body: "We buy, test, and score the tools so you don't waste money on hype.",
    link: "/reviews/",
    linkText: "Compare tools →",
  },
  {
    tag: "02",
    title: "Free ATS checker & fixers",
    body: "Scan your resume and see exactly what to change — no account needed.",
    link: "/tools/ats-checker/",
    linkText: "Scan free →",
  },
  {
    tag: "03",
    title: "ATS-ready templates by role",
    body: "Resume templates built to parse cleanly for your specific job.",
    link: "/templates/",
    linkText: "Browse templates →",
  },
  {
    tag: "04",
    title: "Guides for ATS & interviews",
    body: "Plain-English guides to pass screening and prep for the interview.",
    link: "/resources/",
    linkText: "Read guides →",
  },
];

const fieldNotes = [
  {
    topic: "ATS Mechanics",
    title: "How ATS software actually parses your resume (and where it breaks)",
    link: "#",
  },
  {
    topic: "Keywords",
    title: "The resume keywords that matter for Product Managers",
    link: "#",
  },
  {
    topic: "Formatting",
    title: "Why your PDF might be invisible to an ATS",
    link: "#",
  },
];
---

<Layout>
  <section class="cr-hero">
    <div class="cr-wrap cr-hero__grid">
      <div class="cr-hero__copy">
        <p class="cr-eyebrow">ATS Signal Check — Independent &amp; Free</p>
        <h1 class="cr-h1">See your resume<br />the way the robots do.</h1>
        <p class="cr-lede">
          Most applications are filtered by ATS software before a human ever looks. CareerRadar
          scans your resume against real ATS rules, then shows you the honest, tested tools to
          fix it.
        </p>
        <div class="cr-hero__cta">
          <a class="cr-btn cr-btn--signal" href={withBase("/tools/ats-checker/")}>
            Scan my resume — free
          </a>
          <a class="cr-btn cr-btn--ghost" href={withBase("/best/ai-resume-builder/")}>
            Best AI resume builders →
          </a>
        </div>
        <p class="cr-readout">No signup to scan · Tested against real ATS software</p>
      </div>

      <div class="cr-radar" aria-hidden="true">
        <svg viewBox="0 0 400 400" class="cr-radar__svg">
          <defs>
            <radialGradient id="crGlow" cx="50%" cy="50%" r="50%">
              <stop offset="0%" stop-color="rgba(244,183,64,.18)" />
              <stop offset="100%" stop-color="rgba(244,183,64,0)" />
            </radialGradient>
            <linearGradient id="crSweep" x1="0" y1="0" x2="1" y2="0">
              <stop offset="0%" stop-color="rgba(244,183,64,.55)" />
              <stop offset="100%" stop-color="rgba(244,183,64,0)" />
            </linearGradient>
          </defs>
          <circle cx="200" cy="200" r="190" fill="url(#crGlow)" />
          <g class="cr-radar__rings">
            <circle cx="200" cy="200" r="60" />
            <circle cx="200" cy="200" r="115" />
            <circle cx="200" cy="200" r="170" />
            <line x1="30" y1="200" x2="370" y2="200" />
            <line x1="200" y1="30" x2="200" y2="370" />
          </g>
          <g class="cr-radar__sweep">
            <path d="M200 200 L200 30 A170 170 0 0 1 355 145 Z" fill="url(#crSweep)" />
            <line x1="200" y1="200" x2="200" y2="30" />
          </g>
          <circle class="cr-blip" cx="255" cy="132" r="4" />
          <circle class="cr-blip cr-blip--dim" cx="140" cy="255" r="3" />
          <circle class="cr-blip cr-blip--dim" cx="118" cy="150" r="3" />
          <g class="cr-blip-label">
            <rect x="255" y="108" width="96" height="20" rx="4" />
            <text x="303" y="122">YOUR RESUME</text>
          </g>
        </svg>
      </div>
    </div>
  </section>

  <section class="cr-spotlight">
    <div class="cr-wrap">
      <a class="cr-spotlight__card" href={withBase("/best/ai-resume-builder/")}>
        <div class="cr-spotlight__meta">
          <span class="cr-tick">This month's deep-dive</span>
        </div>
        <h2 class="cr-spotlight__title">
          The best AI resume builders, tested against real ATS software
        </h2>
        <p class="cr-spotlight__body">
          We ran every major AI resume tool through the same ATS gauntlet. Here's what passed,
          what quietly failed, and what's worth paying for.
        </p>
        <span class="cr-link">Read the comparison →</span>
      </a>
    </div>
  </section>

  <section class="cr-pillars">
    <div class="cr-wrap">
      <div class="cr-section-head">
        <p class="cr-eyebrow cr-eyebrow--ink">What CareerRadar covers</p>
        <h2 class="cr-h2">Built around depth, not volume.</h2>
      </div>
      <div class="cr-grid">
        {
          pillars.map((pillar) => (
            <a class="cr-card" href={withBase(pillar.link)}>
              <span class="cr-card__tag">{pillar.tag}</span>
              <h3 class="cr-card__title">{pillar.title}</h3>
              <p class="cr-card__body">{pillar.body}</p>
              <span class="cr-link">{pillar.linkText}</span>
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <section class="cr-notes">
    <div class="cr-wrap">
      <div class="cr-section-head cr-section-head--row">
        <h2 class="cr-h2">Field notes</h2>
        <a class="cr-link" href={withBase("/resources/")}>All guides →</a>
      </div>
      <ul class="cr-notes__list">
        {
          fieldNotes.map((note) => (
            <li>
              <a href={withBase(note.link)}>
                <span class="cr-notes__topic">{note.topic}</span>
                <span class="cr-notes__title">{note.title}</span>
                <span class="cr-notes__arrow" aria-hidden="true">→</span>
              </a>
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  <section class="cr-capture">
    <div class="cr-wrap cr-capture__inner">
      <div>
        <p class="cr-eyebrow">Free download</p>
        <h2 class="cr-capture__title">
          50 ATS-ready resume templates + our interview-question pack
        </h2>
        <p class="cr-capture__sub">
          Get our tested templates and screening tips. One email, no spam.
        </p>
      </div>
      <form class="cr-capture__form" onsubmit="return false">
        <input type="email" placeholder="you@email.com" required />
        <button class="cr-btn cr-btn--signal" type="submit">Send me the pack</button>
      </form>
    </div>
  </section>
</Layout>
