---
import Layout from "../../layouts/Layout.astro";
import QuickAnswer from "../../components/QuickAnswer.astro";
import LeadMagnetGate from "../../components/LeadMagnetGate.astro";
import { guides, type Guide } from "../../data/resources";
import { articleSchema, faqSchema, breadcrumbSchema } from "../../utils/seo";
import { withBase } from "../../utils/site";

export function getStaticPaths() {
  return guides.map((g) => ({ params: { slug: g.slug }, props: { g } }));
}

interface Props {
  g: Guide;
}
const { g } = Astro.props;
const path = `/resources/${g.slug}/`;

const jsonLd = [
  articleSchema({
    headline: g.title,
    description: g.description,
    path,
    dateModified: g.lastVerified ? `${g.lastVerified}-01` : undefined,
  }),
  faqSchema(g.faq.map((f) => ({ question: f.q, answer: f.a }))),
  breadcrumbSchema([
    { name: "Home", path: "/" },
    { name: "Resources", path: "/resources/" },
    { name: g.title, path },
  ]),
];

// ats 相关指南挂 checklist 钩子；其余挂 interview pack（钩子与页面 Intent 对齐，非全站统一）
const isAtsTopic = /ats|resume|keyword/i.test(g.slug);
---

<Layout title={`${g.title} - CareerRadar`} description={g.description} jsonLd={jsonLd}>
  <section class="cr-page">
    <div class="cr-wrap">
      <p class="cr-crumb">
        <a href={withBase("/resources/")}>Resources</a> / Guide
      </p>
      <h1 class="cr-h1" style="font-size:clamp(1.9rem,4.2vw,3rem);margin-top:12px;max-width:26ch;">
        {g.title}
      </h1>

      <QuickAnswer answer={g.quickAnswer} lastVerified={g.lastVerified} />

      {g.sections.map((s) => (
        <>
          <h2 style="margin-top:34px;">{s.h2}</h2>
          {s.body.map((p) => <p>{p}</p>)}
        </>
      ))}

      <div style="margin-top:30px;">
        {isAtsTopic ? (
          <LeadMagnetGate
            variant="ats"
            sourceTag="ats-checklist"
            ctaText="Get the 27-point ATS Repair Checklist (PDF)"
            helperText="Every fix from this guide in a printable audit you can run in 20 minutes."
            modalTitle="The ATS Repair Checklist"
            modalCopy="A 27-point audit to fix a resume that isn't getting interviews — free PDF."
            modalId={`guide-${g.slug}`}
          />
        ) : (
          <LeadMagnetGate
            variant="ats"
            sourceTag="interview-pack"
            ctaText="Get the 50-question interview pack (PDF)"
            helperText="Including the 15 AI-fluency questions most candidates haven't prepped."
            modalTitle="The AI-Era Interview Question Pack"
            modalCopy="50 questions with answer frameworks, 2026 edition — free PDF."
            modalId={`guide-${g.slug}`}
          />
        )}
      </div>

      <h2 style="margin-top:34px;">FAQ</h2>
      {g.faq.map((f) => (
        <details style="margin-top:10px;">
          <summary style="cursor:pointer;font-weight:600;">{f.q}</summary>
          <p style="margin-top:8px;">{f.a}</p>
        </details>
      ))}

      {g.related.length > 0 && (
        <>
          <h2 style="margin-top:34px;">Keep going</h2>
          <ul>
            {g.related.map((r) => (
              <li>
                <a href={withBase(r.href)}>{r.label}</a>
              </li>
            ))}
          </ul>
        </>
      )}
    </div>
  </section>
</Layout>
