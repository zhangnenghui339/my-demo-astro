---
interface Props {
  tag: string;
  tagColorClass: string;
  countText: string;
  title: string;
  description: string;
  link: string;
}

const { tag, tagColorClass, countText, title, description, link } = Astro.props;
---

<a
  href={link}
  class="group flex min-h-[320px] flex-col justify-between rounded-lg border border-zinc-200 bg-white p-6 shadow-sm transition duration-200 hover:-translate-y-1 hover:border-zinc-300 hover:shadow-xl hover:shadow-zinc-200/70"
>
  <div>
    <div class="mb-8 flex items-center justify-between gap-4">
      <span class={`rounded-md px-3 py-1 text-xs font-semibold ${tagColorClass}`}>
        {tag}
      </span>
      <span class="text-xs font-medium text-zinc-400">{countText}</span>
    </div>

    <h3 class="text-xl font-semibold leading-snug text-zinc-950">
      {title}
    </h3>
    <p class="mt-4 text-sm leading-7 text-zinc-500">
      {description}
    </p>
  </div>

  <div class="mt-10 flex items-center justify-between border-t border-zinc-100 pt-5 text-sm font-semibold text-zinc-950">
    <span>Explore pillar</span>
    <span class="transition group-hover:translate-x-1">-&gt;</span>
  </div>
</a>
