---
import "../styles/global.css";

const {
  title = "CareerRadar - Build Your Compounding Career System",
  description = "CareerRadar publishes deep guides, reviews, templates, tools, and resources for modern career operators.",
} = Astro.props;

const navItems = [
  { label: "Reviews", href: "/reviews" },
  { label: "Templates", href: "/templates" },
  { label: "Tools", href: "/tools" },
  { label: "Resources", href: "/resources" },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body class="min-h-screen bg-[#f7f7f4] text-zinc-950 antialiased">
    <div class="min-h-screen bg-[linear-gradient(180deg,#ffffff_0%,#f7f7f4_46%,#ffffff_100%)]">
      <header class="sticky top-0 z-50 border-b border-zinc-200/70 bg-white/82 backdrop-blur-xl">
        <nav class="mx-auto flex h-16 max-w-6xl items-center justify-between px-5 sm:px-8">
          <a href="/" class="flex items-center gap-2 text-[15px] font-semibold text-zinc-950">
            <span class="grid size-8 place-items-center rounded-md bg-zinc-950 text-[11px] font-bold text-white">
              CR
            </span>
            <span>Career<span class="text-blue-600">Radar</span></span>
          </a>

          <div class="hidden items-center gap-8 md:flex">
            {
              navItems.map((item) => (
                <a
                  href={item.href}
                  class="text-sm font-medium text-zinc-500 transition hover:text-zinc-950"
                >
                  {item.label}
                </a>
              ))
            }
          </div>

          <a
            href="#latest-essays"
            class="rounded-md border border-zinc-300 bg-white px-4 py-2 text-sm font-semibold text-zinc-950 shadow-sm transition hover:border-zinc-950"
          >
            Latest Essays
          </a>
        </nav>
      </header>

      <main>
        <slot />
      </main>

      <footer class="border-t border-zinc-200 bg-white">
        <div class="mx-auto flex max-w-6xl flex-col gap-3 px-5 py-8 text-sm text-zinc-500 sm:flex-row sm:items-center sm:justify-between sm:px-8">
          <p>(c) 2026 CareerRadar. All rights reserved.</p>
          <p class="text-zinc-700">Build leverage before you need luck.</p>
        </div>
      </footer>
    </div>
  </body>
</html>
