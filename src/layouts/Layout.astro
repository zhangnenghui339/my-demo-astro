---
import "../styles/careerradar.css";
import { withBase } from "../utils/site";
import { brand, nav, trustLinks, footerRoles } from "../data/site";

interface Props {
  title?: string;
  description?: string;
  jsonLd?: unknown | unknown[];
}

const {
  title = "CareerRadar — See your resume the way the robots do",
  description = "CareerRadar scans your resume against real ATS rules for free, then points you to the honest, tested tools to fix it.",
  jsonLd = [],
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const year = new Date().getFullYear();
const jsonLdItems = Array.isArray(jsonLd) ? jsonLd : [jsonLd];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="impact-site-verification" value="079b1f73-da30-4755-99ca-c1ce6d64e745" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <link rel="icon" type="image/svg+xml" href={withBase("/favicon.svg")} />
    <link rel="icon" href={withBase("/favicon.ico")} />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@500;600;700&family=IBM+Plex+Sans:wght@400;500;600&family=IBM+Plex+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
    {jsonLdItems.map((item) => <script type="application/ld+json" set:html={JSON.stringify(item)} />)}
  </head>
  <body>
    <header class="cr-header">
      <div class="cr-wrap cr-header__row">
        <a class="cr-logo" href={withBase("/")}>
          <span class="cr-logo__mark" aria-hidden="true"></span>{brand.name}
        </a>
        <nav class="cr-nav" aria-label="Primary">
          {nav.map((item) => <a href={withBase(item.href)}>{item.label}</a>)}
        </nav>
        <a class="cr-btn cr-btn--sm" href={withBase("/tools/ats-checker/")}>Scan resume</a>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="cr-footer">
      <div class="cr-wrap">
        <div class="cr-footer__top">
          <div class="cr-footer__brand">
            <a class="cr-logo cr-logo--light" href={withBase("/")}>
              <span class="cr-logo__mark" aria-hidden="true"></span>{brand.name}
            </a>
            <p>{brand.tagline}</p>
          </div>
          <div class="cr-footer__col">
            <h4>Trust</h4>
            {trustLinks.map((item) => <a href={withBase(item.href)}>{item.label}</a>)}
          </div>
          <div class="cr-footer__col">
            <h4>Explore</h4>
            {nav.map((item) => <a href={withBase(item.href)}>{item.label}</a>)}
          </div>
        </div>

        <div class="cr-footer__matrix">
          <h4>Free ATS checker by role</h4>
          <div class="cr-footer__roles">
            {footerRoles.map((r) => <a href={withBase(`/tools/ats-checker/${r.slug}/`)}>{r.label}</a>)}
          </div>
        </div>

        <div class="cr-footer__legal">
          <p>
            {brand.name} is reader-supported. We may earn a commission from links, at no cost to
            you. Reviews stay independent — see
            <a href={withBase("/how-we-test/")}>How We Test</a>.
          </p>
          <p>© {year} {brand.name}</p>
        </div>
      </div>
    </footer>
  </body>
</html>
