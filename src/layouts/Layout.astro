---
import "../styles/careerradar.css";
import { withBase } from "../utils/site";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "CareerRadar — See your resume the way the robots do",
  description = "CareerRadar scans your resume against real ATS rules for free, then points you to the honest, tested tools to fix it.",
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);

const navItems = [
  { label: "Reviews", href: "/reviews/" },
  { label: "Tools", href: "/tools/" },
  { label: "Templates", href: "/templates/" },
  { label: "Resources", href: "/resources/" },
];

const trustLinks = [
  { label: "How We Test", href: "/how-we-test/" },
  { label: "About", href: "/about/" },
  { label: "Disclosure", href: "/disclosure/" },
];

const exploreLinks = [
  { label: "Reviews", href: "/reviews/" },
  { label: "Tools", href: "/tools/" },
  { label: "Templates", href: "/templates/" },
  { label: "Resources", href: "/resources/" },
];

const roleLinks = [
  { label: "Product Manager", href: "/tools/ats-checker/product-manager/" },
  { label: "Software Engineer", href: "/tools/ats-checker/software-engineer/" },
  { label: "Data Analyst", href: "/tools/ats-checker/data-analyst/" },
  { label: "Nurse", href: "/tools/ats-checker/nurse/" },
  { label: "Accountant", href: "/tools/ats-checker/accountant/" },
  { label: "Marketing Manager", href: "/tools/ats-checker/marketing-manager/" },
  { label: "Project Manager", href: "/tools/ats-checker/project-manager/" },
  { label: "Sales Rep", href: "/tools/ats-checker/sales-representative/" },
  { label: "Teacher", href: "/tools/ats-checker/teacher/" },
  { label: "Graphic Designer", href: "/tools/ats-checker/graphic-designer/" },
  { label: "Customer Success", href: "/tools/ats-checker/customer-success/" },
  { label: "Financial Analyst", href: "/tools/ats-checker/financial-analyst/" },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    <link rel="icon" type="image/svg+xml" href={withBase("/favicon.svg")} />
    <link rel="icon" href={withBase("/favicon.ico")} />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@500;600;700&family=IBM+Plex+Sans:wght@400;500;600&family=IBM+Plex+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <header class="cr-header">
      <div class="cr-wrap cr-header__row">
        <a class="cr-logo" href={withBase("/")}>
          <span class="cr-logo__mark" aria-hidden="true"></span>CareerRadar
        </a>
        <nav class="cr-nav" aria-label="Primary">
          {navItems.map((item) => <a href={withBase(item.href)}>{item.label}</a>)}
        </nav>
        <a class="cr-btn cr-btn--sm" href={withBase("/tools/ats-checker/")}>Scan resume</a>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="cr-footer">
      <div class="cr-wrap">
        <div class="cr-footer__top">
          <div class="cr-footer__brand">
            <a class="cr-logo cr-logo--light" href={withBase("/")}>
              <span class="cr-logo__mark" aria-hidden="true"></span>CareerRadar
            </a>
            <p>Build leverage before you need luck.</p>
          </div>
          <div class="cr-footer__col">
            <h4>Trust</h4>
            {trustLinks.map((item) => <a href={withBase(item.href)}>{item.label}</a>)}
          </div>
          <div class="cr-footer__col">
            <h4>Explore</h4>
            {exploreLinks.map((item) => <a href={withBase(item.href)}>{item.label}</a>)}
          </div>
        </div>

        <div class="cr-footer__matrix">
          <h4>Free ATS checker by role</h4>
          <div class="cr-footer__roles">
            {roleLinks.map((item) => <a href={withBase(item.href)}>{item.label}</a>)}
          </div>
        </div>

        <div class="cr-footer__legal">
          <p>
            CareerRadar is reader-supported. We may earn a commission from links, at no cost to
            you. Reviews stay independent — see
            <a href={withBase("/how-we-test/")}>How We Test</a>.
          </p>
          <p>© 2026 CareerRadar</p>
        </div>
      </div>
    </footer>
  </body>
</html>
